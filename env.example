# Copy to .env (git-ignored). Values below are placeholders.

# Postgres via Prisma. For local dev with docker-compose:
DATABASE_URL="postgresql://throughline:throughline@localhost:5433/throughline_admin?schema=admin"
# Direct (non-pooled) connection for migrations; same as DATABASE_URL locally.
DIRECT_URL="postgresql://throughline:throughline@localhost:5433/throughline_admin?schema=admin"
# In production (Supabase): DATABASE_URL uses the transaction pooler on :6543 with
# ?pgbouncer=true&connection_limit=1&schema=admin, DIRECT_URL the session pooler on :5432.

# Auth
AUTH_SECRET="a-long-random-string"            # signs sessions, login links, impersonation tokens
ADMIN_EMAILS="you@example.com"                # comma-separated steward allowlist
ADMIN_ACCESS_KEY="a-long-random-key"          # steward-key login at /login (bootstrap until email is wired)

# Telemetry ingestion — per-service bearer tokens, slug:token comma-separated.
# Slugs: photo-ingestion, genealogy-feed, historical-archive, narrator, weaver, surfer, witness, reunion, scout
SERVICE_TOKENS="weaver:changeme,witness:changeme"

# Optional integrations
# RESEND_API_KEY=""                           # real magic-link + invitation email delivery
# EMAIL_FROM="Throughline <steward@example.com>"
# STRIPE_SECRET_KEY=""                        # real refunds; stub provider used when absent

# Public base URL used in emailed links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Display timezone for "today, 9:12a"-style formatting (defaults to America/Los_Angeles)
# ADMIN_TIMEZONE="America/Los_Angeles"
